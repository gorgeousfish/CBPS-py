# Include essential project files
include pyproject.toml
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include SECURITY.md
include CITATION.cff
include LICENSE*
include requirements.txt

# Include all package data
recursive-include cbps *.py
recursive-include cbps *.csv
recursive-include cbps *.json
include cbps/py.typed

# Include tests
recursive-include tests *.py
recursive-include tests *.json
recursive-include tests *.csv

# Include examples
recursive-include examples *.py
recursive-include examples *.ipynb
include examples/README.md

# Include documentation source files
recursive-include docs *.rst
recursive-include docs *.py
recursive-include docs *.png
recursive-include docs *.ipynb
include docs/Makefile
include docs/make.bat

# Exclude build artifacts and caches
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude .DS_Store
global-exclude *.so
global-exclude .git*

# Exclude documentation build output
prune docs/_build

# Exclude virtual environments
prune .venv
prune venv
prune env

# Exclude IDE settings
prune .vscode
prune .idea
